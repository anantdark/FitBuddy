# Copy to local.properties and adjust paths. Never commit local.properties.

# Android SDK (Android Studio usually writes this automatically)
sdk.dir=/path/to/Android/sdk

# Optional — seeds first-run AI defaults in Settings. App works offline without these.
OPENROUTER_API_KEY=
AI_MODEL=google/gemma-4-31b-it:free

# Optional — Sentry DSN for anonymous crash reports. Empty = crash SDK not initialized.
SENTRY_DSN=

# Optional — cloud backup via the fitbuddy-cloud-backup HTTPS proxy (never commit the key).
# Obfuscated into the APK. Prefer GitHub secret BACKUP_API_KEY for CI.
# Empty key = cloud backup off in this build. Atlas credentials live only in the proxy.
CLOUD_BACKUP_BASE_URL=https://fitbuddy-cloud-backup.vercel.app
BACKUP_API_KEY=
MONGO_DB_NAME=fitbuddy
