# Local/dev signing for assembleRelease on your machine.
# Use a LOCAL keystore (e.g. fitbuddy-local.jks) — never the CI/Play release key.
#
# CI release signing is configured only via GitHub secrets (RELEASE_*),
# not this file. See DISTRIBUTION.md.
#
# NEVER commit keystore.properties or any .jks file to version control.

storeFile=fitbuddy-local.jks
storePassword=your_local_store_password
keyAlias=fitbuddy-local
keyPassword=your_local_key_password
